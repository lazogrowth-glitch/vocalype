{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vocalype",
  "version": "0.7.17",
  "identifier": "com.vocalype.desktop",
  "build": {
    "beforeDevCommand": "bun run dev:frontend",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "url": "desktop/index.html",
        "title": "Vocalype",
        "width": 1348,
        "height": 875,
        "minWidth": 960,
        "minHeight": 624,
        "decorations": false,
        "resizable": true,
        "maximizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; style-src-attr 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data: blob:; connect-src 'self' tauri://localhost https://tauri.localhost http://tauri.localhost http://ipc.localhost https://vocalype.com https://www.vocalype.com https://api.vocalype.com https://api.stripe.com https://checkout.stripe.com; font-src 'self' data:; media-src 'self' asset: https://asset.localhost blob:",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$RESOURCE/**", "$APP/**", "$APPDATA/**", "$APPCONFIG/**"],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": ["resources/**/*"],
    "license": "MIT",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "macOS": {
      "files": {},
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.13",
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist"
    },
    "linux": {
      "deb": {
        "depends": ["libgtk-layer-shell0"]
      },
      "rpm": {
        "compression": {
          "type": "none"
        }
      },
      "appimage": {
        "bundleMediaFramework": true,
        "files": {}
      }
    },
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsi"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["vocalype"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg0REJCOEY3NTkxQTRFOUEKUldTYVRocFo5N2piaEo4SE1CRUlnYUFqellqeWFEODNadEx0aG5rMlkyWFR4dXY2YXlhRy96MFkK",
      "endpoints": [
        "https://vocalype.com/release/latest.json"
      ]
    }
  }
}
