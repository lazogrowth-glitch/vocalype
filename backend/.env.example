# Required
JWT_SECRET=replace-with-32-plus-random-characters

# Recommended admin security
ADMIN_TOKEN_SECRET=replace-with-a-different-32-plus-random-characters
ADMIN_TOKEN_AUDIENCE=vocalype-admin
ADMIN_TOKEN_MAX_AGE_SECONDS=300

# Billing
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_PRICE_ID_INDEPENDENT_MONTHLY=
STRIPE_PRICE_ID_INDEPENDENT_YEARLY=
STRIPE_PRICE_ID_POWER_USER_MONTHLY=
STRIPE_PRICE_ID_POWER_USER_YEARLY=
STRIPE_WEBHOOK_SECRET=

# App URLs
FRONTEND_URL=https://vocalype.com
APP_RETURN_URL=https://vocalype.com
VITE_AUTH_API_URL=https://your-api.example.com

# Backend runtime
PORT=5000
DATABASE_URL=postgresql://user:password@host:5432/dbname
TRUST_X_FORWARDED_FOR=0
CORS_ALLOWED_ORIGINS=https://vocalype.com,https://www.vocalype.com

# Password and token policy
ACCESS_TOKEN_TTL_MINUTES=15
MIN_PASSWORD_LENGTH=12

# License bundle signing (Ed25519)
# Generate with: node -e "const c=require('crypto');const {privateKey}=c.generateKeyPairSync('ed25519');const r=privateKey.export({type:'pkcs8',format:'der'});console.log(r.slice(r.length-32).toString('base64'))"
# Keep this secret — never commit the real value to git.
LICENSE_SIGNING_KEY=replace-with-base64-encoded-32-byte-ed25519-seed

# Premium license policy
LICENSE_GRANT_TTL_SECONDS=3600
LICENSE_REFRESH_INTERVAL_SECONDS=1200
LICENSE_OFFLINE_TTL_SECONDS=259200
LICENSE_REVOCATION_GRACE_SECONDS=86400
LICENSE_AUDIENCE=vocalype-license
LICENSE_ISSUER=vocalype-backend
LICENSE_STRICT_BUILD_APPROVAL=0
LICENSE_ALLOW_DEBUG_BUILDS=1
LICENSE_ALLOWED_CHANNELS=stable,dev
LICENSE_APPROVED_BUILD_HASHES=

# Cloud LLM proxy (Groq) — used by /llm/v1/chat/completions
GROQ_API_KEY=
CLOUD_LLM_MODEL=llama-3.1-8b-instant
CLOUD_LLM_RATE_LIMIT_PER_HOUR=300

# SMTP for password reset
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
