{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VocalType",
  "version": "0.7.17",
  "identifier": "com.vocaltype.desktop",
  "build": {
    "beforeDevCommand": "bun run dev:tauri",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "url": "desktop/index.html",
        "title": "VocalType",
        "width": 800,
        "height": 560,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "maximizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data: blob:; connect-src 'self' tauri://localhost https://tauri.localhost http://tauri.localhost http://localhost:1420 http://127.0.0.1:1420 https://vocaltypeai.com https://www.vocaltypeai.com https://*.up.railway.app https://api.stripe.com https://checkout.stripe.com https://github.com https://objects.githubusercontent.com; font-src 'self' data:; media-src 'self' asset: https://asset.localhost blob:",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$RESOURCE/**", "$APP/**", "$APPDATA/**", "$APPCONFIG/**"],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": ["resources/**/*"],
    "license": "MIT",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "macOS": {
      "files": {},
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.13",
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist"
    },
    "linux": {
      "deb": {
        "depends": ["libgtk-layer-shell0"]
      },
      "rpm": {
        "compression": {
          "type": "none"
        }
      },
      "appimage": {
        "bundleMediaFramework": true,
        "files": {}
      }
    },
    "windows": {}
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg0REJCOEY3NTkxQTRFOUEKUldTYVRocFo5N2piaEo4SE1CRUlnYUFqellqeWFEODNadEx0aG5rMlkyWFR4dXY2YXlhRy96MFkK",
      "endpoints": [
        "https://github.com/lazogrowth-glitch/vocaltype/releases/latest/download/latest.json"
      ]
    }
  }
}
