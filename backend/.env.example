# Required
JWT_SECRET=replace-with-32-plus-random-characters

# Recommended admin security
ADMIN_TOKEN_SECRET=replace-with-a-different-32-plus-random-characters
ADMIN_TOKEN_AUDIENCE=vocalype-admin
ADMIN_TOKEN_MAX_AGE_SECONDS=300

# Billing
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# App URLs
FRONTEND_URL=https://vocalype.com
APP_RETURN_URL=https://vocalype.com
VITE_AUTH_API_URL=https://your-api.example.com

# Backend runtime
PORT=5000
DATABASE_PATH=C:\secure\vocalype\vocalype.db
TRUST_X_FORWARDED_FOR=0
CORS_ALLOWED_ORIGINS=https://vocalype.com,https://www.vocalype.com

# Password and token policy
ACCESS_TOKEN_TTL_MINUTES=15
MIN_PASSWORD_LENGTH=12

# Premium license policy
LICENSE_GRANT_TTL_SECONDS=3600
LICENSE_REFRESH_INTERVAL_SECONDS=1200
LICENSE_OFFLINE_TTL_SECONDS=259200
LICENSE_REVOCATION_GRACE_SECONDS=86400
LICENSE_AUDIENCE=vocalype-license
LICENSE_ISSUER=vocalype-backend
LICENSE_STRICT_BUILD_APPROVAL=0
LICENSE_ALLOW_DEBUG_BUILDS=1
LICENSE_ALLOWED_CHANNELS=stable,dev
LICENSE_APPROVED_BUILD_HASHES=

# SMTP for password reset
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
